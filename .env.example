##################################################
# Database Configuration
##################################################

DB_HOST=localhost
DB_PORT=5432
DB_NAME=prompt_manager
DB_USERNAME=postgres
DB_PASSWORD=postgresql123


##################################################
# Prompt Service
##################################################

PROMPT_SERVICE_PORT=8081
PROMPT_SERVICE_URL=http://localhost:8081


##################################################
# Review Service
##################################################

REVIEW_SERVICE_PORT=8082
REVIEW_SERVICE_URL=http://localhost:8082


##################################################
# Frontend
##################################################

FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

VITE_API_URL=http://localhost:8081
VITE_REVIEW_API_URL=http://localhost:8082


##################################################
# Nginx
##################################################

NGINX_PORT=80
NGINX_SECURE_PORT=443


##################################################
# Environment
##################################################

ENVIRONMENT=development
LOG_LEVEL=debug


##################################################
# JWT Authentication
##################################################

JWT_SECRET=replace-with-a-secret-of-at-least-32-characters
JWT_EXPIRATION_MS=3600000

AUTH_USERNAME=admin
AUTH_PASSWORD=password123


##################################################
# Cloudinary
##################################################

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret